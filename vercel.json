{
  "functions": {
    "api/signals.js": { "memory": 128, "maxDuration": 30 },
    "api/fund-nav.js": { "memory": 128, "maxDuration": 30 },
    "api/fund-detect.js": { "memory": 128, "maxDuration": 15 }
  },
  "routes": [
    { "src": "/api/signals", "dest": "/api/signals.js" },
    { "src": "/api/fund-nav", "dest": "/api/fund-nav.js" },
    { "src": "/api/fund-detect", "dest": "/api/fund-detect.js" },
    { "src": "/(.*)", "dest": "/nasdaq-signal-dashboard.html" }
  ]
}
